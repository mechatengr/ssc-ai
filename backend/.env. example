# =========================================================
# SSC AI Backend - Environment Variables
# Copy this file to ".env" for local use, or paste these
# as "Secrets/Environment Variables" in your host (Render,
# Railway, Fly.io, Cyclic, etc). NEVER commit a real .env file.
# =========================================================

# One or more Gemini API keys, comma-separated.
# Get free keys at https://aistudio.google.com/app/apikey
# Using several keys lets the backend auto-rotate when one
# hits its free-tier quota.
GEMINI_API_KEYS=your_first_key_here,your_second_key_here,your_third_key_here

# Model fallback chain, comma-separated, tried in order.
# Update these any time Google ships newer model names.
GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.0-flash,gemini-1.5-flash

# Comma-separated list of origins allowed to call this API.
# Use * to allow all (fine for a personal project).
ALLOWED_ORIGINS=*

# Port the server listens on (hosts like Render set this for you)
PORT=3000

# Request timeout for a single Gemini call, in ms
REQUEST_TIMEOUT_MS=30000

